# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase Database
SUPABASE_DB_HOST=aws-0-us-west-2.pooler.supabase.com
SUPABASE_DB_USER=postgres.YOUR_PROJECT_ID
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PASSWORD=your_database_password

# Supabase API Keys
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Firebase Auth
FIREBASE_PROJECT_ID=survivorszn

# Cron Job Secret (protects /api/picks/update-results and /api/brackets/update-results)
CRON_SECRET=your-cron-secret-here

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Cloudflare R2 (Profile Image Storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=survivorszn-avatars
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
